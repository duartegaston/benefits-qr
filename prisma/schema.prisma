generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Rubro {
  id      Int     @id @default(autoincrement())
  nombre  String  @unique
  locales Local[]
}

model Local {
  id         String      @id @default(cuid())
  nombre     String?
  email      String      @unique
  password   String?
  googleId   String?     @unique
  logoUrl    String?
  direccion  String?
  lat        Float?
  lng        Float?
  placeId    String?
  telefono   String?
  rubroId    Int?
  rubro      Rubro?      @relation(fields: [rubroId], references: [id])
  createdAt  DateTime    @default(now())
  beneficios Beneficio[]
}

model LocalOtp {
  id              String   @id @default(cuid())
  email           String   @unique
  code            String
  expiresAt       DateTime
  pendingApproval Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Beneficio {
  id              String    @id @default(cuid())
  descripcion     String
  fechaExpiracion DateTime
  maxUsos         Int?
  diasValidos     Int[]     @default([])
  esPublico       Boolean   @default(false)
  requiereDatos   Boolean   @default(true)
  localId         String
  local           Local     @relation(fields: [localId], references: [id])
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?
  reclamos        Reclamo[]

  @@index([localId])
  @@index([deletedAt])
  @@index([esPublico, deletedAt])
}

model Cliente {
  id        String    @id @default(cuid())
  email     String?   @unique
  phone     String?   @unique
  nombre    String?
  createdAt DateTime  @default(now())
  reclamos  Reclamo[]
}

model ClienteOtp {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum EstadoReclamo {
  PENDIENTE
  CANJEADO
  CANCELADO
}

model Reclamo {
  id            String        @id @default(cuid())
  beneficioId   String
  beneficio     Beneficio     @relation(fields: [beneficioId], references: [id])
  clienteId     String
  cliente       Cliente       @relation(fields: [clienteId], references: [id])
  fechaReclamo  DateTime      @default(now())
  fechaCanje    DateTime?
  qrToken       String?       @unique
  qrTokenExpira DateTime?
  estado        EstadoReclamo @default(PENDIENTE)

  @@index([clienteId, estado])
  @@index([beneficioId, estado])
}

enum UserType {
  LOCAL
  CLIENTE
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  userType  UserType
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
